---
import { SITE } from "@config";
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
---

<Layout title={`Kontakt | ${SITE.title}`}>
  <Header activeNav="contact" />

  <main id="main-content">
    <div class="contact-wrapper">
      <h1 class="contact-heading">Kontakt</h1>
      <p class="contact-intro">
        Haben Sie ein Projekt im Kopf? Schreiben Sie mir – ich melde mich
        innerhalb von 24 Stunden bei Ihnen.
      </p>
      <form>
        <label
          for="name"
          class="mb-2 mt-3 block text-base font-medium text-skin-base"
        >
          Name
        </label>
        <input
          class="w-full rounded-md border border-skin-line bg-skin-fill px-2 py-1 text-base text-skin-base focus:border-skin-accent focus:shadow-md focus:outline-none"
          type="text"
          id="name"
          placeholder="Name"
        />
        <label
          for="email"
          class="mt-3 block text-base font-medium text-skin-base"
        >
          Email
        </label>
        <input
          class="w-full rounded-md border border-skin-line bg-skin-fill px-2 py-1 text-base text-skin-base focus:border-skin-accent focus:shadow-md focus:outline-none"
          id="email"
          type="email"
          placeholder="E-Mail"
        />
        <label
          for="subject"
          class="mt-3 block text-base font-medium text-skin-base"
        >
          Betreff
        </label>
        <input
          class="w-full rounded-md border border-skin-line bg-skin-fill px-2 py-1 text-base text-skin-base focus:border-skin-accent focus:shadow-md focus:outline-none"
          id="subject"
          type="text"
          placeholder="Betreff"
        />
        <label
          for="message"
          class="mt-3 block text-base font-medium text-skin-base"
        >
          Nachricht
        </label>
        <textarea
          class="w-full rounded-md border border-skin-line bg-skin-fill px-2 py-1 text-base text-skin-base focus:border-skin-accent focus:shadow-md focus:outline-none"
          id="message"
          rows="5"
          placeholder="Nachricht"></textarea>
        <button
          class="mt-4 rounded-md bg-skin-accent px-8 py-3 text-base font-semibold text-skin-inverted transition-opacity hover:opacity-90"
          type="submit">Absenden</button
        >
      </form>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  #main-content {
    @apply mx-auto flex max-w-3xl flex-1 items-center justify-center px-4;
  }
  .contact-wrapper {
    @apply w-full py-8;
  }
  .contact-heading {
    @apply text-2xl font-semibold text-skin-accent;
  }
  .contact-intro {
    @apply mt-2 mb-4 opacity-80;
  }
</style>
