---
import { SITE } from "@config";
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import LinkButton from "@components/LinkButton.astro";
---

<Layout title={`Nachricht erhalten | ${SITE.title}`}>
  <Header />

  <main id="main-content">
    <div class="danke-wrapper">
      <h1 class="danke-heading">Danke!</h1>
      <p class="danke-text">
        Ihre Nachricht ist angekommen. Ich melde mich innerhalb von 24 Stunden.
      </p>
      <LinkButton
        href="/"
        className="my-6 underline decoration-dashed underline-offset-8 text-lg"
      >
        Zurück zur Startseite
      </LinkButton>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  #main-content {
    @apply mx-auto flex max-w-3xl flex-1 items-center justify-center;
  }
  .danke-wrapper {
    @apply mb-14 flex flex-col items-center justify-center text-center;
  }
  .danke-heading {
    @apply text-5xl font-bold text-skin-accent;
  }
  .danke-text {
    @apply mt-4 text-xl opacity-80;
  }
</style>
