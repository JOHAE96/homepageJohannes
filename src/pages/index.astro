---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import Hr from "@components/Hr.astro";
import ServiceCard from "@components/ServiceCard.astro";
import ServiceProjectCard from "@components/ServiceProjectCard.astro";
import CTASection from "@components/CTASection.astro";
import LinkButton from "@components/LinkButton.astro";
import getSortedProjects from "@utils/getSortedProjects";
import slugify from "@utils/slugify";

const standDate = new Date().toLocaleDateString('de-DE', { month: 'long', year: 'numeric' });
const projects = await getCollection("projects");
const sortedProjects = getSortedProjects(projects);
const featuredProjects = sortedProjects.filter(({ data }) => data.featured);
---

<Layout>
  <Header />
  <main id="main-content">
    <!-- Hero Section -->
    <section id="hero">
      <p class="availability-badge">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon-tabler" aria-hidden="true"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M12 12m-9 0a9 9 0 1 0 18 0a9 9 0 1 0 -18 0" /><path d="M9 12l2 2l4 -4" /></svg>
        Verfügbar ab sofort · Vollzeit · Remote-first · Deutsch & Englisch · Stand: {standDate}
      </p>
      <h1>Fullstack-Entwickler & KI-Ingenieur für Enterprise-Projekte</h1>
      <p class="hero-facts">
        4+ Jahre Enterprise-Erfahrung · Web-Apps & KI-Integration · Branchen: Versicherung, E-Learning, Startups
      </p>
      <p>
        Ich entwickle Web-Apps, integriere KI in bestehende Workflows – und
        helfe Teams, AI-Tools mit den richtigen Guardrails produktiv
        einzusetzen.
      </p>
      <div class="cta-group">
        <a href="/contact" class="cta-btn">
          Kostenloses Erstgespräch buchen
        </a>
        <a href="mailto:hello@johanneshaeuser.de" class="cta-link-secondary">
          oder direkt per E-Mail
        </a>
      </div>
    </section>

    <Hr />

    <!-- Tech-Stack Übersicht -->
    <section id="stack">
      <p class="stack-label">Stack</p>
      <div class="stack-categories">
        <div class="stack-category">
          <span class="stack-cat-label">Frontend</span>
          <div class="stack-tags">
            <span>Vue</span>
            <span>Angular</span>
            <span>React</span>
            <span>TypeScript</span>
          </div>
        </div>
        <div class="stack-category">
          <span class="stack-cat-label">Backend</span>
          <div class="stack-tags">
            <span>Spring Boot</span>
            <span>Node.js</span>
            <span>Python</span>
            <span>Flutter</span>
          </div>
        </div>
        <div class="stack-category">
          <span class="stack-cat-label">AI / KI</span>
          <div class="stack-tags">
            <span>RAG</span>
            <span>LLM / MCP</span>
            <span>LlamaIndex</span>
          </div>
        </div>
        <div class="stack-category">
          <span class="stack-cat-label">Infra</span>
          <div class="stack-tags">
            <span>PostgreSQL</span>
            <span>Kubernetes</span>
          </div>
        </div>
      </div>
    </section>

    <Hr />

    <!-- Webentwicklung & IT -->
    <section id="webentwicklung">
      <h2>Webentwicklung & IT</h2>
      <div class="services-grid">
        <ServiceCard
          title="Web-App-Prototypen"
          description="MVP in 2–4 Wochen mit Vue, Astro, Svelte React oder Angular – ideal für Startups & Pitch-Decks."
        />
        <ServiceCard
          title="Optimierung & Support"
          description="Performance-Boost & Wartung – monatlich ab 20h."
        />
      </div>
    </section>

    <Hr />

    <!-- KI-Engineering -->
    <section id="ki-engineering">
      <h2>KI-Engineering</h2>
      <div class="services-grid">
        <ServiceCard
          title="RAG-Systeme"
          description="Hochperformante Retrieval-Augmented-Generation-Pipelines mit Vektor-Datenbanken für präzise, kontextbezogene KI-Antworten."
        />
        <ServiceCard
          title="MCP & LLM Tooling"
          description="Tool-Design und Agenten-Orchestrierung – LLMs sicher mit APIs, Datenbanken und externen Systemen verbinden."
        />
        <ServiceCard
          title="KI-gestützte Workflows"
          description="Automatisierung von Entwicklungsprozessen: Prompt Engineering, Code-Generierung und Qualitätssicherung."
        />
        <ServiceCard
          title="Spec-Driven Development"
          description="Strukturierte KI-Entwicklung mit klaren Spezifikationen – vom Anforderungsdokument bis zum getesteten Feature. Kein Vibe Coding, sondern nachvollziehbare Ingenieurspraxis."
        />
        <ServiceCard
          title="AI-Tool-Adoption für Entwicklungsteams"
          description="Ich helfe Teams dabei, KI-Tools wie Cursor, Claude oder Copilot strukturiert einzuführen – mit klaren Guardrails, passenden Workflows und dem richtigen Tool für den jeweiligen Kontext. Kein Hype, sondern pragmatische Integration in den Entwicklungsalltag."
        />
      </div>
    </section>

    <Hr />

    <!-- Ausgewählte Projekte -->
    {featuredProjects.length > 0 && (
      <section id="projekte">
        <h2>Ausgewählte Projekte</h2>
        <ul class="projects-grid">
          {featuredProjects.map(({ data }) => (
            <ServiceProjectCard
              href={`/projects/${slugify(data)}`}
              frontmatter={data}
            />
          ))}
        </ul>
        <div class="all-projects-btn-wrapper">
          <LinkButton href="/projects">
            Alle Projekte
            <svg xmlns="http://www.w3.org/2000/svg"
              ><path
                d="m11.293 17.293 1.414 1.414L19.414 12l-6.707-6.707-1.414 1.414L15.586 11H6v2h9.586z"
              ></path>
            </svg>
          </LinkButton>
        </div>
      </section>
    )}

    <Hr />

    <!-- So läuft ein Projekt ab -->
    <section id="prozess">
      <h2>So läuft ein Projekt ab</h2>
      <ol class="process-list">
        <li>
          <strong>Erstgespräch</strong> – Kostenlos, 30 Min. Ich verstehe dein Problem, du lernst mich kennen.
        </li>
        <li>
          <strong>Konzept & Spec</strong> – Gemeinsam definieren wir Scope, Technologie und Meilensteine – schriftlich, klar, nachvollziehbar.
        </li>
        <li>
          <strong>Umsetzung</strong> – Allein oder im Team, remote oder hybrid. Regelmäßige Check-ins, kein Blackbox-Development.
        </li>
        <li>
          <strong>Review & Launch</strong> – Code Reviews, Tests, gemeinsamer Abnahme-Prozess.
        </li>
        <li>
          <strong>Nach dem Launch</strong> – Optional: Weiterentwicklung, Support, Übergabe an interne Teams.
        </li>
      </ol>
    </section>

    <Hr />

    <!-- CTA / Kontakt -->
    <section id="kontakt">
      <CTASection
        heading="Bereit, Ihr Projekt zu starten?"
        text="Lassen Sie uns in einem kostenlosen Erstgespräch darüber sprechen, wie ich Ihnen helfen kann."
        buttonText="Kontakt aufnehmen"
        buttonHref="/contact"
      />
    </section>
  </main>

  <Footer />
</Layout>

<style>
  /* ===== Hero Section ===== */
  #hero {
    @apply pb-6 pt-8;
  }
  #hero .availability-badge {
    @apply mb-4 inline-flex items-center gap-1.5 rounded-full bg-skin-accent bg-opacity-10 px-4 py-1 text-sm font-medium text-skin-accent;
  }
  #hero h1 {
    @apply my-4 inline-block text-3xl font-bold sm:my-8 sm:text-5xl;
  }
  #hero p {
    @apply my-2 max-w-xl;
  }
  .hero-facts {
    @apply text-sm font-medium opacity-60;
    max-width: none;
  }
  .cta-group {
    @apply mt-6 flex flex-wrap items-center gap-4;
  }
  .cta-btn {
    @apply inline-block rounded-md bg-skin-accent px-6 py-3 font-semibold text-skin-inverted transition-opacity hover:opacity-90;
  }
  .cta-link-secondary {
    @apply text-sm text-skin-accent decoration-dashed underline-offset-4 hover:underline;
  }

  /* ===== Tech-Stack Section ===== */
  #stack {
    @apply py-6;
  }
  .stack-label {
    @apply mb-3 text-xs font-semibold uppercase tracking-widest opacity-50;
  }
  .stack-categories {
    @apply flex flex-col gap-3;
  }
  .stack-category {
    @apply flex flex-wrap items-center gap-2;
  }
  .stack-cat-label {
    @apply w-16 shrink-0 text-xs font-semibold uppercase tracking-wider opacity-50;
  }
  .stack-tags {
    @apply flex flex-wrap gap-2;
  }
  .stack-tags span {
    @apply rounded-md border border-skin-line px-3 py-1 text-sm font-medium;
  }

  /* ===== Services Sections ===== */
  #webentwicklung,
  #ki-engineering {
    @apply pb-6 pt-12;
  }
  #webentwicklung h2,
  #ki-engineering h2 {
    @apply text-2xl font-semibold tracking-wide;
  }
  .services-grid {
    @apply mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2;
  }

  /* ===== Projects Section ===== */
  #projekte {
    @apply pb-6 pt-12;
  }
  #projekte h2 {
    @apply text-2xl font-semibold tracking-wide;
  }
  .projects-grid {
    @apply mt-6 grid gap-6;
  }
  .all-projects-btn-wrapper {
    @apply my-8 text-center;
  }

  /* ===== Process Section ===== */
  #prozess {
    @apply pb-6 pt-12;
  }
  #prozess h2 {
    @apply text-2xl font-semibold tracking-wide;
  }
  .process-list {
    @apply mt-6 space-y-4 pl-0;
    counter-reset: process-counter;
    list-style: none;
  }
  .process-list li {
    @apply flex gap-4;
    counter-increment: process-counter;
  }
  .process-list li::before {
    content: counter(process-counter);
    @apply flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-skin-accent text-sm font-bold text-skin-inverted;
  }

  /* ===== CTA Section ===== */
  #kontakt {
    @apply pb-6 pt-6;
  }
</style>
