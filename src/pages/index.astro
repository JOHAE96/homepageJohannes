---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import Hr from "@components/Hr.astro";
import ServiceCard from "@components/ServiceCard.astro";
import ServiceProjectCard from "@components/ServiceProjectCard.astro";
import CTASection from "@components/CTASection.astro";
import LinkButton from "@components/LinkButton.astro";
import getSortedProjects from "@utils/getSortedProjects";
import slugify from "@utils/slugify";

const projects = await getCollection("projects");
const sortedProjects = getSortedProjects(projects);
const featuredProjects = sortedProjects.filter(({ data }) => data.featured);
---

<Layout>
  <Header />
  <main id="main-content">
    <!-- Hero Section -->
    <section id="hero">
      <h1>Web- & KI-Engineering</h1>
      <p>
        Als Freelance-Ingenieur unterstütze ich Unternehmen dabei,
        leistungsfähige Webanwendungen und intelligente KI-Systeme zu bauen –
        vom ersten Prototyp bis zur produktionsreifen Lösung.
      </p>
      <a href="#kontakt" class="cta-btn">
        Kostenloses Erstgespräch buchen
      </a>
    </section>

    <Hr />

    <!-- Webentwicklung & IT -->
    <section id="webentwicklung">
      <h2>Webentwicklung & IT</h2>
      <div class="services-grid">
        <ServiceCard
          title="Web-App-Prototypen"
          description="MVP in 2–4 Wochen mit Vue, Astro, React oder Angular – ideal für Startups & Pitch-Decks."
        />
        <ServiceCard
          title="Frontend-Übernahme"
          description="Integration in bestehende Teams (Next.js, Tailwind) für Agenturen & KMU."
        />
        <ServiceCard
          title="Digitale Souveränität"
          description="Beratung & Umsetzung von Open-Source-Lösungen (z.B. Nextcloud, Passbolt) für KMU und Vereine."
        />
        <ServiceCard
          title="Spezialprojekte"
          description="AR/VR-Integration oder Event-Apps (z.B. Buchungsplattformen) für Kultur & Messen."
        />
        <ServiceCard
          title="Optimierung & Support"
          description="Performance-Boost & Wartung – monatlich ab 20h."
        />
      </div>
      <p class="pricing-info">
        Remote deutschlandweit verfügbar
      </p>
    </section>

    <Hr />

    <!-- KI-Engineering -->
    <section id="ki-engineering">
      <h2>KI-Engineering</h2>
      <div class="services-grid">
        <ServiceCard
          title="RAG-Systeme"
          description="Hochperformante Retrieval-Augmented-Generation-Pipelines mit Vektor-Datenbanken für präzise, kontextbezogene KI-Antworten."
        />
        <ServiceCard
          title="MCP & LLM Tooling"
          description="Tool-Design und Agenten-Orchestrierung – LLMs sicher mit APIs, Datenbanken und externen Systemen verbinden."
        />
        <ServiceCard
          title="KI-gestützte Workflows"
          description="Automatisierung von Entwicklungsprozessen: Prompt Engineering, Code-Generierung und Qualitätssicherung."
        />
      </div>
    </section>

    <Hr />

    <!-- Ausgewählte Projekte -->
    {featuredProjects.length > 0 && (
      <section id="projekte">
        <h2>Ausgewählte Projekte</h2>
        <ul class="projects-grid">
          {featuredProjects.map(({ data }) => (
            <ServiceProjectCard
              href={`/projects/${slugify(data)}`}
              frontmatter={data}
            />
          ))}
        </ul>
        <div class="all-projects-btn-wrapper">
          <LinkButton href="/projects">
            Alle Projekte
            <svg xmlns="http://www.w3.org/2000/svg"
              ><path
                d="m11.293 17.293 1.414 1.414L19.414 12l-6.707-6.707-1.414 1.414L15.586 11H6v2h9.586z"
              ></path>
            </svg>
          </LinkButton>
        </div>
      </section>
    )}

    <Hr />

    <!-- CTA / Kontakt -->
    <section id="kontakt">
      <CTASection
        heading="Bereit, Ihr Projekt zu starten?"
        text="Lassen Sie uns in einem kostenlosen Erstgespräch darüber sprechen, wie ich Ihnen helfen kann."
        buttonText="Kontakt aufnehmen"
        buttonHref="/contact"
      />
    </section>
  </main>

  <Footer />
</Layout>

<style>
  /* ===== Hero Section ===== */
  #hero {
    @apply pb-6 pt-8;
  }
  #hero h1 {
    @apply my-4 inline-block text-3xl font-bold sm:my-8 sm:text-5xl;
  }
  #hero p {
    @apply my-2 max-w-xl;
  }
  .cta-btn {
    @apply mt-6 inline-block rounded-md bg-skin-accent px-6 py-3 font-semibold text-skin-inverted transition-opacity hover:opacity-90;
  }

  /* ===== Services Sections ===== */
  #webentwicklung,
  #ki-engineering {
    @apply pb-6 pt-12;
  }
  #webentwicklung h2,
  #ki-engineering h2 {
    @apply text-2xl font-semibold tracking-wide;
  }
  .services-grid {
    @apply mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2;
  }
  .pricing-info {
    @apply mt-6 text-center text-sm opacity-75;
  }

  /* ===== Projects Section ===== */
  #projekte {
    @apply pb-6 pt-12;
  }
  #projekte h2 {
    @apply text-2xl font-semibold tracking-wide;
  }
  .projects-grid {
    @apply mt-6 grid gap-6;
  }
  .all-projects-btn-wrapper {
    @apply my-8 text-center;
  }

  /* ===== CTA Section ===== */
  #kontakt {
    @apply pb-6 pt-6;
  }
</style>
