---
export interface Props {
  heading: string;
  text: string;
  buttonText: string;
  buttonHref: string;
}

const { heading, text, buttonText, buttonHref } = Astro.props;
---

<div class="cta-wrapper">
  <h2 class="cta-heading">{heading}</h2>
  <p class="cta-text">{text}</p>
  <a href={buttonHref} class="cta-button">
    {buttonText}
  </a>
</div>

<style>
  .cta-wrapper {
    @apply py-12 text-center;
  }
  .cta-heading {
    @apply text-2xl font-semibold tracking-wide;
  }
  .cta-text {
    @apply mx-auto mt-4 max-w-xl opacity-80;
  }
  .cta-button {
    @apply mt-6 inline-block rounded-md bg-skin-accent px-6 py-3 font-semibold text-skin-inverted transition-opacity hover:opacity-90;
  }
</style>
